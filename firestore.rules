// ============================================================
// RÈGLES DE SÉCURITÉ FIRESTORE — catalogue de pièces moto
// ------------------------------------------------------------
// La base est interrogée directement depuis le navigateur :
// sans règles, n'importe qui peut tout lire ET tout écrire.
//
// Pendant le développement, le « mode test » autorise tout
// pendant ~30 jours. Avant la soutenance, collez les règles
// ci-dessous dans la console Firebase :
//   Firestore Database > Règles > Publier
// ============================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /produits/{id} {
      // Lecture publique : tout le monde peut consulter le catalogue
      allow read: if true;

      // Écriture ouverte pour la durée du projet. L'interface de
      // gestion (admin.html) est protégée par mot de passe, mais c'est
      // une protection CÔTÉ CLIENT : seule cette règle protège la base.
      // ⚠️ En production réelle, on restreindrait aux utilisateurs
      //    connectés (Firebase Authentication) :
      //    allow write: if request.auth != null;
      allow write: if true;
    }

    // Tout le reste de la base est verrouillé
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
